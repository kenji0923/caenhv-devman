# caenhv-devman server configuration via environment.
# Usage:  server.py --env-file /opt/caenhv-devman/server.env
#    or:  DEVMAN_ENV_FILE=/opt/caenhv-devman/server.env server.py
#    or:  systemd EnvironmentFile=/opt/caenhv-devman/server.env
# Real environment variables take precedence over this file.

# --- server (generated CLI flags all have DEVMAN_* equivalents) ---
DEVMAN_BACKEND_MODULE=caen_libs.caenhvwrapper
DEVMAN_HOST=0.0.0.0
DEVMAN_PORT=50250
DEVMAN_DB=/opt/caenhv-devman/ownership.db
DEVMAN_INIT_FILE=/opt/caenhv-devman/server_hooks.py
DEVMAN_DEINIT_FILE=/opt/caenhv-devman/server_hooks.py
DEVMAN_CLIENT_LEASE_SEC=90
# Seconds between server read-cache refreshes (0 disables; Device_get_* served from cache when > 0).
# Keep this <= WATCHDOG_INTERVAL_SEC below: the watchdog reads Status through the
# cache, so a slower refresh here bounds trip-detection latency.
DEVMAN_CACHE_POLL_INTERVAL=1
#DEVMAN_VERBOSE=1

# --- crate connection (hook args; DEVMAN_HOOK_ARG_<KEY> or plain <KEY>) ---
DEVMAN_HOOK_ARG_ADDRESS=192.168.1.100
DEVMAN_HOOK_ARG_SYSTEM_TYPE=SY4527
DEVMAN_HOOK_ARG_LINK_TYPE=TCPIP
DEVMAN_HOOK_ARG_USERNAME=admin
DEVMAN_HOOK_ARG_PASSWORD=secret
#DEVMAN_HOOK_ARG_KEEPALIVE_SEC=10

# --- trip watchdog (CAEN policy in server_hooks.py; 0 disables) ---
DEVMAN_HOOK_ARG_WATCHDOG_INTERVAL_SEC=1.0

# --- Telegraf logging (disabled unless telegraf_url is set) ---
#DEVMAN_HOOK_ARG_TELEGRAF_URL=udp://192.168.1.50:8094
#DEVMAN_HOOK_ARG_TELEGRAF_MEASUREMENT=caenhv
#DEVMAN_HOOK_ARG_TELEGRAF_HOST=laserlablinux0
#DEVMAN_HOOK_ARG_TELEGRAF_INTERVAL_SEC=10
